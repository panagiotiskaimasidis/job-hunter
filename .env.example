# Copy this to .env and fill in values — or just run `python setup.py` which writes it for you.
# NEVER commit .env to version control.

# ── Required: the AI brain ──────────────────────────────────────────
GROQ_API_KEY=            # free at console.groq.com

# ── Optional: AI backup (used automatically if Groq is busy) ────────
GEMINI_API_KEY=          # free at aistudio.google.com/apikey

# ── Optional: Notion dashboard (leave blank to skip) ────────────────
NOTION_API_KEY=          # notion.so/my-integrations
NOTION_DATABASE_ID=      # run `python setup_notion.py` to create one

# ── Tuning (sensible defaults) ──────────────────────────────────────
MIN_MATCH_SCORE=7        # 1-10; jobs below this are skipped
SCRAPE_DELAY_SECONDS=2   # seconds between requests per site
MAX_JOBS_PER_BOARD=15    # max jobs fetched per search
