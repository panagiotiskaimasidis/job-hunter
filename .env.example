# Copy this to .env and fill in values
# NEVER commit .env to version control

# Required
ANTHROPIC_API_KEY=sk-ant-...

# Notion (optional — skip if you don't need Notion logging)
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Pipeline tuning
MIN_MATCH_SCORE=7          # 1-10; jobs below this threshold are skipped
SCRAPE_DELAY_SECONDS=3     # seconds between requests per domain
MAX_JOBS_PER_BOARD=30      # max jobs fetched per query/location combo

# Claude model
CLAUDE_MODEL=claude-sonnet-4-5-20251022

# LinkedIn auth (optional — only needed if public scraping is blocked)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
